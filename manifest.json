{
  "manifestVersion": 5,
  "id": "com.fayelab.opencurve",
  "name": "OpenCurve",
  "version": "1.0.0",
  "main": "index.html",
  "host": {
    "app": "premierepro",
    "minVersion": "25.1.0"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "opencurve-panel",
      "label": { "default": "OpenCurve" },
      "minimumSize":           { "width": 380, "height": 440 },
      "maximumSize":           { "width": 840, "height": 900 },
      "preferredDockedSize":   { "width": 420, "height": 500 },
      "preferredFloatingSize": { "width": 440, "height": 540 }
    }
  ],
  "requiredPermissions": {
    "clipboard": "readAndWrite"
  },
  "icons": [
    {
      "width": 23, "height": 23,
      "path": "icons/icon-dark.png",
      "scale": [1, 2],
      "theme": ["darkest", "dark", "medium"]
    },
    {
      "width": 48, "height": 48,
      "path": "icons/plugin-icon-dark.png",
      "scale": [1, 2],
      "species": ["pluginList"],
      "theme": ["darkest", "dark", "medium"]
    }
  ]
}
